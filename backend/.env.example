APP_NAME=AI Legal System Backend
APP_ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api
BACKEND_CORS_ORIGINS=http://localhost:3010
STORAGE_PATH=/app/storage
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=legal_documents
QDRANT_COLLECTION_ALIAS=legal_documents_active
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379/0
EXACT_CACHE_ENABLED=false
EXACT_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_TTL_SECONDS=7200
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.93
SEMANTIC_CACHE_TOP_K=3
RESPONSE_SCHEMA_VERSION=v1
STRATEGY_PROMPT_VERSION=v1
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL_NAME=Alibaba-NLP/gte-multilingual-base
EMBEDDING_FALLBACK_PROVIDER=hash
EMBEDDING_HASH_DIMENSION=384
# LLM provider: "deepseek" | "openai" | "mock"
LLM_PROVIDER=deepseek
# DeepSeek model: deepseek-chat (cheapest) | deepseek-reasoner (o1-like)
LLM_MODEL=deepseek-chat
LLM_API_KEY=
CHUNK_SIZE=1200
CHUNK_OVERLAP=180
TOP_K_DEFAULT=6
